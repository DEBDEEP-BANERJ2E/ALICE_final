    "# ── Cell 7: Full Analysis Dashboard ──────────────────────────────────\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.gridspec as gridspec\n",
    "import numpy as np\n",
    "\n",
    "fig = plt.figure(figsize=(18, 20))\n",
    "gs  = gridspec.GridSpec(4, 2, figure=fig, hspace=0.45, wspace=0.35)\n",
    "\n",
    "# ── 1. Reward over time ───────────────────────────────────────────────\n",
    "ax1 = fig.add_subplot(gs[0, 0])\n",
    "window = 10\n",
    "smoothed = np.convolve(all_rewards, np.ones(window)/window, mode='valid')\n",
    "ax1.plot(all_rewards, alpha=0.3, color='#4a90e2', linewidth=0.8, label='raw')\n",
    "ax1.plot(range(window-1, len(all_rewards)), smoothed, color='#4a90e2', linewidth=2, label=f'{window}-ep MA')\n",
    "ax1.axhline(0, color='gray', linestyle='--', alpha=0.5)\n",
    "ax1.set_title('Reward Over Time', fontweight='bold')\n",
    "ax1.set_xlabel('Episode'); ax1.set_ylabel('Reward')\n",
    "ax1.legend(fontsize=8)\n",
    "\n",
    "# ── 2. Reward distribution ────────────────────────────────────────────\n",
    "ax2 = fig.add_subplot(gs[0, 1])\n",
    "ax2.hist(all_rewards, bins=20, color='#4a90e2', edgecolor='white', alpha=0.85)\n",
    "ax2.axvline(np.mean(all_rewards), color='red', linestyle='--', label=f'mean={np.mean(all_rewards):.3f}')\n",
    "ax2.set_title('Reward Distribution', fontweight='bold')\n",
    "ax2.set_xlabel('Reward'); ax2.set_ylabel('Count')\n",
    "ax2.legend(fontsize=8)\n",
    "\n",
    "# ── 3. Success rate over time ─────────────────────────────────────────\n",
    "ax3 = fig.add_subplot(gs[1, 0])\n",
