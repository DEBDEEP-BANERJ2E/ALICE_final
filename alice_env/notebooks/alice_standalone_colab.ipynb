    "    ax7.legend(fontsize=8)\n",
    "else:\n",
    "    ax7.text(0.5, 0.5, 'No failures recorded', ha='center', va='center', transform=ax7.transAxes)\n",
    "ax7.set_title(f'Failure Bank Novelty (n={len(failure_bank._entries)})', fontweight='bold')\n",
    "ax7.set_xlabel('Novelty Score'); ax7.set_ylabel('Count')\n",
