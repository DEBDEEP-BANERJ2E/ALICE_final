    "    for j, seed in enumerate(DOMAIN_SEEDS[domain]):\n",
    "        perf = curriculum.task_perf.get(seed, [])\n",
    "        heatmap[i, j] = sum(perf)/len(perf) if perf else 0.0\n",
    "im = ax6.imshow(heatmap, cmap='RdYlGn', vmin=0, vmax=1, aspect='auto')\n",
    "ax6.set_xticks([0,1,2]); ax6.set_xticklabels(['Task 1','Task 2','Task 3'], fontsize=8)\n",
    "ax6.set_yticks(range(len(domains))); ax6.set_yticklabels(domains, fontsize=9)\n",
    "ax6.set_title('Curriculum Heatmap (success rate)', fontweight='bold')\n",
