   "source": [
    "# ── Cell 3: Embedded ALICE Environment (no server needed) ─────────────\n",
    "import random, time, uuid, json, threading\n",
    "from dataclasses import dataclass, field, asdict\n",
    "from typing import Any, Dict, List, Optional\n",
    "from collections import defaultdict\n",
    "\n",
    "# ── Domain seed tasks ────────────────────────────────────────────────\n",
    "DOMAIN_SEEDS = {\n",
    "    'arithmetic': [\n",
    "        'What is 15 * 7 - 3?',\n",
    "        'Sum of all even numbers from 1 to 20.',\n",
    "        'A train at 60 mph for 2.5 hours — how far?',\n",
    "    ],\n",
    "    'logic': [\n",
    "        'All mammals breathe air. Whales are mammals. Do whales breathe air?',\n",
    "        'If P→Q and Q→R, does P→R?',\n",
    "        'Three mislabeled boxes (apples/oranges/mixed). Pick one fruit from the mixed-labeled box. Which box is which?',\n",
    "    ],\n",
    "    'code': [\n",
    "        'Write Python to check if a string is a palindrome.',\n",
    "        'Find the second largest number in a list.',\n",
    "        'Return the Fibonacci number at position n.',\n",
    "    ],\n",
    "    'factual': [\n",
    "        'Capital of Australia?',\n",
    "        'Largest planet in our solar system?',\n",
    "        'Year World War II ended?',\n",
    "    ],\n",
    "    'symbolic': [\n",
    "        'Simplify: (x² - 4) / (x - 2)',\n",
    "        'Solve: 3x + 7 = 22',\n",
    "        'Derivative of x³ + 2x?',\n",
    "    ],\n",
    "}\n",
    "ALL_SEEDS = [t for tasks in DOMAIN_SEEDS.values() for t in tasks]\n",
    "\n",
    "# ── Verifier (T1 rule-based, T2 keyword judge, T3 regression) ────────\n",
    "def verify(action: str, task: str) -> Dict[str, Any]:\n",
    "    action_l = action.lower()\n",
    "    task_l   = task.lower()\n",
    "    # T1: non-empty, minimum length\n",
    "    t1 = 1.0 if len(action.strip()) >= 5 else 0.0\n",
    "    # T2: keyword overlap judge\n",
    "    task_kw  = set(task_l.split())\n",
    "    ans_kw   = set(action_l.split())\n",
    "    overlap  = len(task_kw & ans_kw) / max(len(task_kw), 1)\n",
    "    t2 = min(1.0, overlap * 3)  # scale up small overlaps\n",
    "    # T3: regression — penalise very short or repetitive answers\n",
    "    t3 = 1.0 if len(set(action.split())) > 3 else 0.5\n",
    "    composite = 0.5 * t1 + 0.3 * t2 + 0.2 * t3\n",
    "    return {'tier1_score': t1, 'tier2_score': t2, 'tier3_score': t3,\n",
    "            'composite_score': composite, 'success': composite >= 0.5}\n",
    "\n",
    "# ── Reward function (Bellman-shaped) ─────────────────────────────────\n",
    "MIN_REWARD = 0.01\n",
    "GAMMA      = 0.99\n",
    "\n",
    "def compute_reward(verification, turn_number, prev_action='', action='',\n",
    "                   disc_before=0.0, disc_after=0.0) -> float:\n",
    "    t1, t2, t3 = verification['tier1_score'], verification['tier2_score'], verification['tier3_score']\n",
    "    decay = 0.1 * (turn_number - 1)\n",
    "    if turn_number == 1:\n",
    "        raw = t1\n",
    "    elif turn_number == 2:\n",
    "        raw = 0.8 * t2 - decay\n",
    "    else:\n",
    "        rep = 0.02 if action == prev_action and action else 0.0\n",
    "        raw = t1 * t3 * (1 - 2 * decay) - rep\n",
    "    raw = raw if raw != 0.0 else MIN_REWARD\n",
    "    shaped = raw + GAMMA * disc_after - disc_before\n",
    "    return max(-1.0, min(1.0, shaped))\n",
    "\n",
    "# ── Curriculum manager ────────────────────────────────────────────────\n",
    "class CurriculumManager:\n",
    "    def __init__(self):\n",
    "        self.task_perf: Dict[str, List[float]] = defaultdict(list)\n",
    "        self.difficulty_tier = 1\n",
    "        self._ep_since_escalate = 0\n",
    "\n",
    "    def update(self, task: str, success: bool):\n",
    "        self.task_perf[task].append(1.0 if success else 0.0)\n",
    "        self._ep_since_escalate += 1\n",
    "        if self._ep_since_escalate >= 20:\n",
    "            rates = [sum(v)/len(v) for v in self.task_perf.values() if v]\n",
    "            avg   = sum(rates) / len(rates) if rates else 0.0\n",
    "            if avg > 0.7 and self.difficulty_tier < 10:\n",
    "                self.difficulty_tier += 1\n",
    "            self._ep_since_escalate = 0\n",
    "\n",
    "    def discrimination_coverage(self) -> float:\n",
    "        rates = [sum(v)/len(v) for v in self.task_perf.values() if v]\n",
    "        if not rates: return 0.0\n",
    "        in_zone = sum(1 for r in rates if 0.2 <= r <= 0.8)\n",
    "        return in_zone / len(rates)\n",
    "\n",
    "    def pick_task(self) -> str:\n",
    "        # Prefer tasks in discrimination zone (20-80% success)\n",
    "        zone = [t for t, v in self.task_perf.items()\n",
    "                if v and 0.2 <= sum(v)/len(v) <= 0.8]\n",
    "        pool = zone if zone else ALL_SEEDS\n",
    "        return random.choice(pool)\n",
    "\n",
    "# ── Failure bank ──────────────────────────────────────────────────────\n",
    "@dataclass\n",
    "class FailureEntry:\n",
    "    failure_id:    str\n",
    "    task:          str\n",
    "    action:        str\n",
    "    composite:     float\n",
    "    turn:          int\n",
    "    novelty_score: float = 0.0\n",
    "    timestamp:     str   = field(default_factory=lambda: time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime()))\n",
    "\n",
    "class FailureBank:\n",
    "    def __init__(self):\n",
    "        self._entries: List[FailureEntry] = []\n",
    "\n",
    "    def add(self, task, action, composite, turn):\n",
    "        # Simple novelty: 1 - max cosine sim to existing entries (word-level)\n",
    "        def bow(s): return set(s.lower().split())\n",
    "        def sim(a, b):\n",
    "            u, v = bow(a), bow(b)\n",
    "            return len(u & v) / max(len(u | v), 1)\n",
    "        if self._entries:\n",
    "            max_sim = max(sim(task, e.task) for e in self._entries)\n",
    "            novelty = 1.0 - max_sim\n",
    "        else:\n",
    "            novelty = 1.0\n",
    "        if novelty > 0.3:  # only store novel failures\n",
    "            self._entries.append(FailureEntry(\n",
    "                failure_id=str(uuid.uuid4())[:8],\n",
    "                task=task, action=action, composite=composite,\n",
    "                turn=turn, novelty_score=round(novelty, 3)\n",
    "            ))\n",
    "\n",
    "    def summary(self) -> Dict:\n",
    "        if not self._entries: return {'count': 0, 'avg_novelty': 0.0, 'avg_composite': 0.0}\n",
    "        return {\n",
    "            'count':         len(self._entries),\n",
    "            'avg_novelty':   round(sum(e.novelty_score for e in self._entries) / len(self._entries), 3),\n",
    "            'avg_composite': round(sum(e.composite for e in self._entries) / len(self._entries), 3),\n",
    "        }\n",
    "\n",
    "# ── Leaderboard ───────────────────────────────────────────────────────\n",
    "BENCHMARK_SCORES = {\n",
    "    'Qwen/Qwen2.5-0.5B-Instruct':          {'avg_reward': 0.41, 'success_rate': 0.38, 'disc_coverage': 0.44, 'params_b': 0.5},\n",
    "    'Qwen/Qwen2.5-1.5B-Instruct':          {'avg_reward': 0.53, 'success_rate': 0.49, 'disc_coverage': 0.55, 'params_b': 1.5},\n",
    "    'Qwen/Qwen2.5-3B-Instruct':            {'avg_reward': 0.61, 'success_rate': 0.57, 'disc_coverage': 0.63, 'params_b': 3.0},\n",
    "    'HuggingFaceTB/SmolLM2-1.7B-Instruct': {'avg_reward': 0.48, 'success_rate': 0.45, 'disc_coverage': 0.50, 'params_b': 1.7},\n",
    "    'google/gemma-3-1b-it':                {'avg_reward': 0.44, 'success_rate': 0.41, 'disc_coverage': 0.47, 'params_b': 1.0},\n",
    "}\n",
    "\n",
    "class Leaderboard:\n",
    "    def __init__(self):\n",
    "        self._entries = {mid: dict(s, model_id=mid, episodes_run=0, source='benchmark')\n",
    "                         for mid, s in BENCHMARK_SCORES.items()}\n",
    "\n",
    "    def rl_score(self, e): return 0.5*e['avg_reward'] + 0.3*e['success_rate'] + 0.2*e['disc_coverage']\n",
    "\n",
    "    def update(self, model_id, avg_reward, success_rate, disc_coverage, episodes_run):\n",
    "        if model_id not in self._entries:\n",
    "            self._entries[model_id] = {'model_id': model_id, 'params_b': 0.0, 'source': 'user'}\n",
    "        e = self._entries[model_id]\n",
    "        e.update({'avg_reward': round(avg_reward,4), 'success_rate': round(success_rate,4),\n",
    "                  'disc_coverage': round(disc_coverage,4), 'episodes_run': episodes_run})\n",
    "\n",
    "    def table(self):\n",
    "        rows = sorted(self._entries.values(), key=self.rl_score, reverse=True)\n",
    "        return [{'rank': i+1, **r, 'rl_score': round(self.rl_score(r), 4)} for i, r in enumerate(rows)]\n",
    "\n",
    "# ── Instantiate shared state ──────────────────────────────────────────\n",
    "curriculum = CurriculumManager()\n",
    "failure_bank = FailureBank()\n",
    "leaderboard  = Leaderboard()\n",
    "\n",
    "print('✅ ALICE environment ready (embedded, no server needed)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load_model",
   "metadata": {},
