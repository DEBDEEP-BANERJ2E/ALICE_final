   "source": [
    "# ── Cell 4: Load model with 4-bit QLoRA ───────────────────────────────\n",
    "import torch\n",
    "from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig\n",
    "from peft import LoraConfig, get_peft_model, TaskType\n",
    "\n",
    "if HF_TOKEN:\n",
    "    from huggingface_hub import login\n",
    "    login(HF_TOKEN)\n",
    "    print('✅ Logged in to HF Hub')\n",
    "\n",
    "print(f'Loading tokenizer: {MODEL_ID}')\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_ID, trust_remote_code=True)\n",
    "if tokenizer.pad_token is None:\n",
    "    tokenizer.pad_token = tokenizer.eos_token\n",
    "\n",
    "bnb_cfg = BitsAndBytesConfig(\n",
    "    load_in_4bit=LOAD_IN_4BIT,\n",
    "    bnb_4bit_quant_type='nf4',\n",
    "    bnb_4bit_use_double_quant=True,\n",
    "    bnb_4bit_compute_dtype=torch.bfloat16,\n",
    ") if LOAD_IN_4BIT else None\n",
    "\n",
    "print(f'Loading model (4-bit={LOAD_IN_4BIT})...')\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    MODEL_ID,\n",
    "    quantization_config=bnb_cfg,\n",
    "    device_map='auto',\n",
    "    trust_remote_code=True,\n",
    "    torch_dtype=torch.bfloat16,\n",
    ")\n",
    "lora_cfg = LoraConfig(\n",
    "    task_type=TaskType.CAUSAL_LM, r=16, lora_alpha=32,\n",
    "    target_modules=['q_proj', 'v_proj'], lora_dropout=0.05, bias='none',\n",
    ")\n",
    "model = get_peft_model(model, lora_cfg)\n",
    "model.print_trainable_parameters()\n",
    "print('✅ Model ready')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "rollout_fns",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 5: Rollout helpers ───────────────────────────────────────────\n",
    "def sample_response(prompt: str) -> str:\n",
    "    device = next(model.parameters()).device\n",
    "    cot = f'<task>{prompt}</task>\\nThink step by step, then give your final answer.\\n<reasoning>'\n",
    "    inputs = tokenizer(cot, return_tensors='pt', truncation=True, max_length=512).to(device)\n",
    "    with torch.no_grad():\n",
    "        out = model.generate(\n",
    "            **inputs, max_new_tokens=MAX_NEW_TOKENS,\n",
    "            do_sample=True, temperature=0.8, top_p=0.9,\n",
    "            pad_token_id=tokenizer.pad_token_id,\n",
    "        )\n",
    "    gen_ids = out[0][inputs['input_ids'].shape[1]:]\n",
    "    return tokenizer.decode(gen_ids, skip_special_tokens=True).strip()\n",
    "\n",
    "def run_episode() -> Dict:\n",
    "    task = curriculum.pick_task() if curriculum.task_perf else random.choice(ALL_SEEDS)\n",
    "    total_reward = 0.0\n",
    "    prev_action  = ''\n",
    "    disc         = curriculum.discrimination_coverage()\n",
    "    for turn in range(1, MAX_TURNS + 1):\n",
    "        action = sample_response(task)\n",
    "        v      = verify(action, task)\n",
    "        r      = compute_reward(v, turn, prev_action, action, disc, disc)\n",
    "        total_reward += r\n",
    "        prev_action   = action\n",
    "        if v['success']: break\n",
    "        if not v['success'] and turn < MAX_TURNS:\n",
    "            failure_bank.add(task, action, v['composite_score'], turn)\n",
    "    curriculum.update(task, v['success'])\n",
    "    return {'task': task, 'action': action, 'reward': total_reward,\n",
    "            'success': v['success'], 'composite': v['composite_score']}\n",
    "\n",
    "def collect_rollouts() -> tuple:\n",
    "    prompts, responses, rewards = [], [], []\n",
    "    for _ in range(GROUP_SIZE):\n",
    "        try:\n",
    "            ep = run_episode()\n",
    "            prompts.append(ep['task'])\n",
    "            responses.append(ep['action'])\n",
    "            rewards.append(ep['reward'])\n",
    "        except Exception as exc:\n",
    "            print(f'Rollout error (skipped): {exc}')\n",
    "    return prompts, responses, rewards\n",
    "\n",
    "print('✅ Rollout functions defined')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "training",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 6: GRPO Training loop ────────────────────────────────────────\n",
    "optimizer = torch.optim.AdamW(model.parameters(), lr=LR)\n",
    "\n",
    "all_rewards, all_successes, all_losses = [], [], []\n",
    "disc_history = []\n",
    "\n",
    "for ep in range(1, EPISODES + 1):\n",
    "    prompts, responses, rewards = collect_rollouts()\n",
    "    if not rewards:\n",
    "        continue\n",
    "\n",
    "    # GRPO: group-normalised advantages\n",
    "    rewards_t  = torch.tensor(rewards, dtype=torch.float32)\n",
    "    advantages = (rewards_t - rewards_t.mean()) / (rewards_t.std().clamp(min=1e-6))\n",
    "    device     = next(model.parameters()).device\n",
    "    total_loss = torch.tensor(0.0, device=device)\n",
    "\n",
    "    for adv, prompt, response in zip(advantages, prompts, responses):\n",
    "        full_text  = prompt + '\\n' + response\n",
    "        inputs     = tokenizer(full_text, return_tensors='pt', truncation=True, max_length=768).to(device)\n",
    "        labels     = inputs['input_ids'].clone()\n",
    "        prompt_len = len(tokenizer(prompt, return_tensors='pt')['input_ids'][0])\n",
    "        labels[0, :prompt_len] = -100\n",
    "        out        = model(**inputs, labels=labels)\n",
    "        log_prob   = -out.loss\n",
    "        kl_pen     = KL_COEF * (log_prob ** 2)\n",
    "        total_loss = total_loss + (-(adv.to(device) * log_prob) + kl_pen)\n",
    "\n",
    "    total_loss = total_loss / max(len(rewards), 1)\n",
    "    optimizer.zero_grad()\n",
    "    total_loss.backward()\n",
    "    torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "    optimizer.step()\n",
    "\n",
    "    all_rewards.extend(rewards)\n",
    "    all_successes.extend([1.0 if r > 0.3 else 0.0 for r in rewards])\n",
    "    all_losses.append(float(total_loss.detach()))\n",
    "    disc_history.append(curriculum.discrimination_coverage())\n",
    "\n",
    "    avg_r    = sum(all_rewards[-50:])   / max(len(all_rewards[-50:]),   1)\n",
    "    avg_succ = sum(all_successes[-50:]) / max(len(all_successes[-50:]), 1)\n",
    "    disc     = curriculum.discrimination_coverage()\n",
    "\n",
    "    if ep % 5 == 0:\n",
    "        print(f'Ep {ep:4d} | loss={all_losses[-1]:.4f} | avg_reward={avg_r:.4f} | '\n",
    "              f'success={avg_succ:.2%} | disc_cov={disc:.2%} | tier={curriculum.difficulty_tier}')\n",
    "\n",
    "    # Push to leaderboard every 10 episodes\n",
    "    if ep % 10 == 0:\n",
    "        leaderboard.update(MODEL_ID, avg_r, avg_succ, disc, ep)\n",
    "\n",
    "print(f'\\n✅ Training complete!')\n",
    "print(f'Final avg_reward={avg_r:.4f} | success={avg_succ:.2%} | episodes={len(all_rewards)}')\n",
    "print(f'Failure bank: {failure_bank.summary()}')\n",
    "print(f'Curriculum tier: {curriculum.difficulty_tier}')"
   ]
  },
