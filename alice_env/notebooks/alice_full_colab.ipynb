    "# ╔══════════════════════════════════════════════════════════════════╗\n",
    "# ║  CELL 5 — START ALICE SERVER LOCALLY                           ║\n",
    "# ╚══════════════════════════════════════════════════════════════════╝\n",
    "import subprocess, time, httpx, os, sys\n",
