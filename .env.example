# Hugging Face
HF_TOKEN=hf_your_token_here

# OpenAI-compatible API
API_BASE_URL=https://api-inference.huggingface.co/v1
MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0
API_KEY=${HF_TOKEN}

# Environment config
PORT=8000

# Reference models
OPENAI_API_KEY=sk_your_openai_key_here
REFERENCE_MODEL_PRIMARY=gpt-4o
REFERENCE_MODEL_SECONDARY=Qwen/Qwen2.5-72B-Instruct

# Target agent model
AGENT_MODEL_ID=Qwen/Qwen2.5-7B-Instruct

# Training hyperparameters
GRPO_GROUP_SIZE=8
LEARNING_RATE=1e-5
DISCOUNT_FACTOR=0.99
KL_BETA=0.01
CLIP_EPSILON=0.2
MAX_NEW_TOKENS=512

# Curriculum
DISCRIMINATION_DELTA=0.25
MIN_EPISODES_BETWEEN_ESCALATIONS=50

# Reward shaping
ATTEMPT_DECAY_WEIGHT=0.1
NOVELTY_PENALTY_WEIGHT=0.05
REPETITION_PENALTY_WEIGHT=0.02
LAMBDA_JUDGE=0.3

# Verifier
SANDBOX_TIMEOUT=5
SANDBOX_MEMORY_MB=512
REGRESSION_BATTERY_SIZE=20

# Failure Bank
FAILURE_BANK_MAX_SIZE=10000
NOVELTY_THRESHOLD=0.7
TOP_K_SNAPSHOT=16

# Dashboard
GRADIO_PORT=7860
DASHBOARD_POLL_INTERVAL=1
